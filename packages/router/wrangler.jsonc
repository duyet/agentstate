{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentstate",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",

  // Custom domain is configured via Workers Custom Domains API
  // No "routes" needed — all traffic to agentstate.app hits this worker

  "workers_dev": true,

  "observability": {
    "enabled": true
  },

  "services": [
    {
      "binding": "API",
      "service": "agentstate-api"
    },
    {
      "binding": "DASHBOARD",
      "service": "agentstate-dashboard"
    }
  ],

  "vars": {
    "ROUTES": "{\"routes\":[{\"path\":\"/api\",\"binding\":\"API\"},{\"path\":\"/v1\",\"binding\":\"API\"},{\"path\":\"/llms.txt\",\"binding\":\"API\"},{\"path\":\"/agents.md\",\"binding\":\"API\"},{\"path\":\"/\",\"binding\":\"DASHBOARD\"}],\"smoothTransitions\":true}",
    "ASSET_PREFIXES": "[\"/_next/\",\"/static/\",\"/assets/\"]"
  }
}
