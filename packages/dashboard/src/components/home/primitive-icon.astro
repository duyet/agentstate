---
/** Minimal geometric icon set — matches the hand-rolled stroke style used
 * elsewhere on the marketing site (theme toggle, logo). One shape per feature,
 * 20x20, inherits currentColor. The `name` prop accepts either the five
 * primitives or any supporting-feature category key. */
interface Props {
  name: string;
  class?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: used in the template below
const { name, class: cls = "" } = Astro.props;
---
<svg viewBox="0 0 20 20" class={cls} fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {name === "state" && (
    <>
      <rect x="3" y="3" width="14" height="4.2" rx="1.4" />
      <rect x="3" y="8.9" width="14" height="4.2" rx="1.4" opacity="0.6" />
      <rect x="3" y="14.8" width="14" height="2.2" rx="1.1" opacity="0.3" />
    </>
  )}
  {name === "lease" && (
    <>
      <rect x="4.5" y="9" width="11" height="8" rx="1.6" />
      <path d="M7 9V6a3 3 0 0 1 6 0v3" />
    </>
  )}
  {name === "claim" && (
    <>
      <path d="M10 2.5 16.5 5.5v4.4c0 4-2.7 6.8-6.5 7.6-3.8-.8-6.5-3.6-6.5-7.6V5.5L10 2.5Z" />
      <path d="M7.3 10 9.3 12l3.4-4" />
    </>
  )}
  {name === "token" && (
    <>
      <circle cx="7.5" cy="7.5" r="4.5" />
      <path d="M10.7 10.7 16.5 16.5M13.3 14 15 12.3M15.3 16 17 14.3" />
    </>
  )}
  {name === "conversation" && (
    <path d="M3 5.5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H8.5L5 16.5V13.5H5a2 2 0 0 1-2-2v-6Z" />
  )}
  {name === "auth" && (
    <>
      <circle cx="10" cy="7" r="3.5" />
      <path d="M4 17c0-3.3 2.7-5.5 6-5.5s6 2.2 6 5.5" />
    </>
  )}
  {name === "ai" && (
    <>
      <path d="M10 3v2.2M10 14.8V17M3 10h2.2M14.8 10H17" />
      <rect x="6" y="6" width="8" height="8" rx="2" />
      <circle cx="8.5" cy="8.5" r="0.8" fill="currentColor" stroke="none" />
      <circle cx="11.5" cy="8.5" r="0.8" fill="currentColor" stroke="none" />
      <path d="M8.5 12.5h3" />
    </>
  )}
  {name === "search" && (
    <>
      <circle cx="8.5" cy="8.5" r="5" />
      <path d="M12.5 12.5 17 17" />
    </>
  )}
  {name === "tags" && (
    <>
      <path d="M3 3h6l8 8-6 6-8-8V3Z" />
      <circle cx="6" cy="6" r="1" fill="currentColor" stroke="none" />
    </>
  )}
  {name === "bulk" && (
    <>
      <path d="M4 5h12M4 10h12M4 15h8" />
      <path d="M14.5 13v5M12 15.5h5" />
    </>
  )}
  {name === "analytics" && (
    <>
      <path d="M3 16.5V3.5M3 16.5h14" />
      <path d="M6.5 13.5l3-3.5 3 2.5 4-6" opacity="0.9" />
    </>
  )}
  {name === "tracing" && (
    <>
      <circle cx="5" cy="5" r="1.6" />
      <circle cx="15" cy="5" r="1.6" />
      <circle cx="10" cy="15" r="1.6" />
      <path d="M5 6.6v3.4a3 3 0 0 0 3 3h2M15 6.6v3.4a3 3 0 0 1-3 3h-2" />
    </>
  )}
  {name === "webhooks" && (
    <>
      <path d="M10 3.5a4 4 0 0 1 4 4v1.5a2 2 0 0 0 2 2h1.2a2.8 2.8 0 0 0 0-5.6" opacity="0.5" />
      <path d="M10 16.5a4 4 0 0 1-4-4v-1.5a2 2 0 0 0-2-2H2.8a2.8 2.8 0 0 0 0 5.6" opacity="0.5" />
      <path d="M10 7v6M7.5 10.5 10 13l2.5-2.5" />
    </>
  )}
  {name === "domains" && (
    <>
      <circle cx="10" cy="10" r="7" />
      <path d="M3 10h14M10 3c2.2 2.2 2.2 11.8 0 14M10 3c-2.2 2.2-2.2 11.8 0 14" opacity="0.6" />
