  )}
  {name === "mcp" && (
    <>
      <rect x="3" y="3" width="14" height="14" rx="2.5" />
      <path d="M8 7v6M8 13h-2.5M8 7H5.5M12.5 7v6M12.5 7H15M12.5 13h2.5" opacity="0.8" />
    </>
  )}
  {name === "oauth" && (
    <>
      <rect x="3.5" y="9.5" width="13" height="8" rx="1.6" />
      <path d="M6.5 9.5V7a3.5 3.5 0 0 1 7 0v2.5" />
      <circle cx="10" cy="13" r="1.1" fill="currentColor" stroke="none" />
    </>
  )}
  {name === "orgs" && (
    <>
      <rect x="3" y="4" width="14" height="5" rx="1.4" />
      <rect x="3" y="11" width="14" height="5" rx="1.4" opacity="0.55" />
      <circle cx="6" cy="6.5" r="0.9" fill="currentColor" stroke="none" />
      <circle cx="6" cy="13.5" r="0.9" fill="currentColor" stroke="none" />
    </>
  )}
  {name === "projects" && (
    <>
      <path d="M3 6a2 2 0 0 1 2-2h3l1.5 2h5.5a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Z" />
      <path d="M8 11h4" opacity="0.6" />
    </>
  )}
  {name === "adapters" && (
    <>
      <path d="M6 4 4 6l2 2M14 4l2 2-2 2" />
      <path d="M3.5 6h3M13.5 6h3" />
      <path d="M10 8.5 10 12M8.5 10 10 12l1.5-2" opacity="0.6" />
    </>
  )}
  {name === "tracing-header" && (
    <path d="M3 4h14v3H3zM3 9h9v3H3zM3 14h12v2.5H3z" opacity="0.85" />
  )}
  {name === "docs" && (
    <>
      <path d="M5 3h7l3 3v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" />
      <path d="M12 3v3h3" opacity="0.6" />
      <path d="M7 9h6M7 12h6" opacity="0.6" />
    </>
  )}
  {name === "pagination" && (
    <>
      <path d="M8 6 5 9l3 3M12 6l3 3-3 3" opacity="0.8" />
      <path d="M10 5v10" stroke-dasharray="0.1 3" />
    </>
  )}
</svg>
