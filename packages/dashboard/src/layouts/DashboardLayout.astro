---
import RootLayout from "./RootLayout.astro";
// New design-system tokens (base/panel/fg/edge/accent …). Imported by the
// dashboard layout so routes rebuilt onto AppShell resolve the token classes.
// Keeps the marketing-only import in MarketingLayout.astro unchanged.
import "../styles/tokens.css";
---

<!--
  Dashboard layout shell. Phase-2 dashboard pages use this layout and render a
  single client:only React island that wraps its content in <DashboardShell>
  (which provides the Clerk Providers + auth gate + sidebar/header chrome).
  See src/components/dashboard-shell.tsx for the usage pattern.
-->
<RootLayout>
  <slot />
</RootLayout>
