{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentstate-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "compatibility_flags": ["nodejs_compat"],

  "observability": {
    "enabled": true
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentstate-db",
      "database_id": "aa60936a-b12d-421a-b5d3-d8b8bed917c4",
      "migrations_dir": "drizzle"
    }
  ],

  "ai": {
    "binding": "AI"
  }
}
