{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentstate",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "../dashboard/out",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },

  "observability": {
    "enabled": true
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentstate-db",
      "database_id": "aa60936a-b12d-421a-b5d3-d8b8bed917c4",
      "migrations_dir": "drizzle"
    }
  ],

  "ai": {
    "binding": "AI"
  },

  "kv_namespaces": [
    {
      "binding": "AUTH_CACHE",
      "id": "3deb979337f24b9cb5edc1f7d8825e3a"
    }
  ]
}
