{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentstate-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "compatibility_flags": ["nodejs_compat"],

  // When agentstate.app DNS is configured, uncomment this route:
  // "routes": [
  //   { "pattern": "agentstate.app/api/*", "zone_name": "agentstate.app" }
  // ],

  // Workers Observability — logs, traces, metrics
  "observability": {
    "enabled": true
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentstate-db",
      "database_id": "aa60936a-b12d-421a-b5d3-d8b8bed917c4",
      "migrations_dir": "drizzle"
    }
  ],

  // Workers AI for title generation and follow-up questions
  "ai": {
    "binding": "AI"
  },

  // Static content served from src/content/static.ts (compiled into worker)
  "logpush": false
}
