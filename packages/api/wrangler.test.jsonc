{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentstate-api-test",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "compatibility_flags": ["nodejs_compat"],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentstate-db",
      "database_id": "test-db-id",
      "migrations_dir": "drizzle"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "STATE_STREAM_HUB",
        "class_name": "StateStreamHub"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1_state_stream_hub",
      "new_sqlite_classes": ["StateStreamHub"]
    }
  ],

  // No AI binding — tests mock it via miniflare bindings
  "vars": {
    "PROJECT_CREATION_RATE_LIMIT_MAX": "10000",
    "RATE_LIMIT_MAX": "10000"
  },
  "logpush": false
}
