{
  "name": "@agentstate/sdk",
  "version": "0.1.3",
  "description": "TypeScript SDK for AgentState — conversation history for AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk.d.ts",
      "import": "./dist/ai-sdk.mjs",
      "require": "./dist/ai-sdk.js"
    },
    "./langgraph": {
      "types": "./dist/langgraph.d.ts",
      "import": "./dist/langgraph.mjs",
      "require": "./dist/langgraph.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/ai-sdk.ts src/langgraph.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@langchain/langgraph-checkpoint": "^1.1.1"
  },
  "peerDependenciesMeta": {
    "@langchain/langgraph-checkpoint": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/duyet/agentstate",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "devDependencies": {
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph-checkpoint": "^1.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
