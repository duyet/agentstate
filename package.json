{
  "name": "agentstate",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev -w packages/api",
    "build": "npm run build -w packages/api",
    "deploy": "npm run deploy -w packages/api",
    "db:generate": "npm run db:generate -w packages/api",
    "db:migrate": "npm run db:migrate -w packages/api",
    "typecheck": "tsc --noEmit -p packages/api/tsconfig.json"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
